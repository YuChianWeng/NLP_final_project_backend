# App Settings
APP_ENV=development

# Database Settings
DATABASE_URL=sqlite:///./movie_insight.db

# Azure OpenAI Settings
AZURE_OPENAI_API_KEY=your_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name

# Azure AI Language Settings (Sentiment & Summarization)
AZURE_LANGUAGE_API_KEY=your_language_api_key_here
AZURE_LANGUAGE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# Azure AI Speech Settings (TTS)
AZURE_SPEECH_API_KEY=your_speech_api_key_here
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_VOICE_NAME=zh-TW-HsiaoChenNeural